<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:DigitalTwinSimulation.UI.ViewModels"
        mc:Ignorable="d"
        x:Class="DigitalTwinSimulation.UI.Views.SupplementaryDetailWindow"
        x:DataType="vm:SupplementaryDetailWindowViewModel"
        Title="Supplementary Detail"
        Width="900"
        Height="700">

    <DockPanel Margin="20">

        <Border DockPanel.Dock="Top"
                Background="{Binding StatusColorHex}"
                CornerRadius="8"
                Padding="14"
                Margin="0,0,0,16">

            <StackPanel Spacing="8">
                <TextBlock Text="{Binding MonitorName}"
                           FontSize="26"
                           FontWeight="Bold"/>

                <WrapPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding StatusText, StringFormat='Status: {0}'}"
                               FontSize="15"
                               Margin="0,0,20,0"/>

                    <TextBlock Text="{Binding StopTypeText, StringFormat='Stop: {0}'}"
                               FontSize="15"
                               Margin="0,0,20,0"/>

                    <TextBlock Text="{Binding IsActivated, StringFormat='Activated: {0}'}"
                               FontSize="15"/>
                </WrapPanel>

                <TextBlock Text="{Binding ReasonText, StringFormat='Reason: {0}'}"
                           FontSize="15"
                           TextWrapping="Wrap"/>
            </StackPanel>

        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <StackPanel Spacing="16">

                <Border Padding="12"
                        BorderThickness="1"
                        CornerRadius="6">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Powertrain Buffer Summary"
                                   FontSize="18"
                                   FontWeight="Bold"/>

                        <UniformGrid Columns="2">
                            <TextBlock Text="{Binding ReadyPowertrainCount, StringFormat='Ready Powertrains: {0}'}"/>
                            <TextBlock Text="{Binding ReadyPowertrainCapacity, StringFormat='Capacity: {0}'}"/>

                            <TextBlock Text="{Binding ReadyPowertrainUsagePercentage, StringFormat='Usage: {0:F1}%'}"/>
                            <TextBlock Text="{Binding NextReadyPowertrainVinText, StringFormat='Next Ready VIN: {0}'}"/>

                            <TextBlock Text="{Binding CurrentMarriageVinText, StringFormat='Marriage VIN: {0}'}"/>
                            <TextBlock Text="{Binding IsCurrentMarriagePowertrainReady, StringFormat='Powertrain Ready: {0}'}"/>

                            <TextBlock Text="{Binding IsOutputBlockedByReadyBuffer, StringFormat='Output Blocked By Buffer: {0}'}"/>
                            <TextBlock Text="{Binding EngineDressingMovementCountLastTakt, StringFormat='ED Moves Last Takt: {0}'}"/>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Padding="12"
                        BorderThickness="1"
                        CornerRadius="6">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Engine Dressing Stations"
                                   FontSize="18"
                                   FontWeight="Bold"/>

                        <ItemsControl ItemsSource="{Binding EngineDressingStations}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:StationDetailItemViewModel">
                                    <Border Margin="0,0,0,10"
                                            Padding="10"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <StackPanel Spacing="6">

                                            <WrapPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding StationId}"
                                                           FontWeight="Bold"
                                                           Width="110"/>

                                                <TextBlock Text="{Binding VinText, StringFormat='VIN: {0}'}"
                                                           Width="190"/>

                                                <TextBlock Text="{Binding StateText, StringFormat='State: {0}'}"
                                                           Width="170"/>

                                                <TextBlock Text="{Binding WearText, StringFormat='Wear: {0}'}"/>
                                            </WrapPanel>

                                            <ProgressBar Minimum="0"
                                                         Maximum="100"
                                                         Value="{Binding WearPercentage}"
                                                         Height="12"/>

                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>

        </ScrollViewer>

    </DockPanel>
</Window>