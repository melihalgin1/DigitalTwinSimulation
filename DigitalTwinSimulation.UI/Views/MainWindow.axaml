<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:DigitalTwinSimulation.UI.ViewModels"
        mc:Ignorable="d"
        x:Class="DigitalTwinSimulation.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Digital Twin Simulation"
        Width="1250"
        Height="900">

    <DockPanel Margin="20">

        <StackPanel DockPanel.Dock="Top" Spacing="12">

            <TextBlock Text="Automotive Assembly Digital Twin"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

            <WrapPanel HorizontalAlignment="Center"
                       Orientation="Horizontal">

                <TextBlock Text="{Binding CurrentTakt, StringFormat='Current Takt: {0}'}"
                           FontSize="16"
                           Margin="12,0"/>

                <TextBlock Text="{Binding SimulatedElapsedTimeText, StringFormat='Simulated Time: {0}'}"
                           FontSize="16"
                           Margin="12,0"/>

                <TextBlock Text="{Binding FinishedVehicleCount, StringFormat='Finished Vehicles: {0}'}"
                           FontSize="16"
                           Margin="12,0"/>

                <TextBlock Text="{Binding RunStateText, StringFormat='State: {0}'}"
                           FontSize="16"
                           Margin="12,0"/>

            </WrapPanel>

            <WrapPanel HorizontalAlignment="Center"
                       Orientation="Horizontal">

                <TextBlock Text="{Binding ReadyPowertrainCount, StringFormat='Ready Powertrains: {0}'}"
                           FontSize="15"
                           Margin="12,0"/>

                <TextBlock Text="{Binding NextReadyPowertrainVin, StringFormat='Next Ready Powertrain VIN: {0}'}"
                           FontSize="15"
                           Margin="12,0"/>

            </WrapPanel>

            <Border Padding="10"
                    BorderThickness="1"
                    CornerRadius="6"
                    HorizontalAlignment="Center">

                <StackPanel Spacing="10">

                    <WrapPanel Orientation="Horizontal"
                               HorizontalAlignment="Center">

                        <Button Content="{Binding StartPauseButtonText}"
                                Click="StartPause_Click"
                                Width="120"
                                Margin="6,0"/>

                        <Button Content="Step Takt"
                                Click="StepTakt_Click"
                                Width="120"
                                Margin="6,0"/>

                        <Button Content="Reset"
                                Click="ResetSimulation_Click"
                                Width="120"
                                Margin="6,0"/>

                    </WrapPanel>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Spacing="10">

                        <TextBlock Text="Takt Duration"
                                   VerticalAlignment="Center"/>

                        <Slider Minimum="0.5"
                                Maximum="2.0"
                                Width="260"
                                Value="{Binding TaktDurationMinutes, Mode=TwoWay}"/>

                        <TextBlock Text="{Binding TaktDurationDisplayText}"
                                   Width="90"
                                   VerticalAlignment="Center"/>

                    </StackPanel>

                </StackPanel>

            </Border>

        </StackPanel>

        <ScrollViewer Margin="0,20,0,0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <Border Padding="10"
                    BorderThickness="1"
                    CornerRadius="6">

                <StackPanel Spacing="10">

                    <TextBlock Text="Plant Status Monitors"
                               FontWeight="Bold"
                               FontSize="20"/>

                    <ItemsControl ItemsSource="{Binding GroupMonitors}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:GroupMonitorItemViewModel">
                                <Button Margin="0,0,12,12"
                                        Padding="0"
                                        MinWidth="220"
                                        MinHeight="170"
                                        Click="GroupMonitor_Click">
                                    <Border Background="{Binding StatusColorHex}"
                                            CornerRadius="8"
                                            Padding="12">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="{Binding GroupName}"
                                                       FontWeight="Bold"
                                                       FontSize="18"/>

                                            <TextBlock Text="{Binding StatusText, StringFormat='Status: {0}'}"/>
                                            <TextBlock Text="{Binding StopTypeText, StringFormat='Stop: {0}'}"/>
                                            <TextBlock Text="{Binding ReasonText, StringFormat='Reason: {0}'}"
                                                       TextWrapping="Wrap"/>

                                            <TextBlock Text="{Binding FaultedStations, StringFormat='Faulted Stations: {0}'}"/>
                                            <TextBlock Text="{Binding EmptyStations, StringFormat='Empty Stations: {0}'}"/>
                                            <TextBlock Text="{Binding AverageWear, StringFormat='Avg Wear: {0:F1}%'}"/>
                                            <TextBlock Text="{Binding MovementCountLastTakt, StringFormat='Moves Last Takt: {0}'}"/>
                                        </StackPanel>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <WrapPanel Orientation="Horizontal">

                        <Button Padding="0"
                                MinWidth="300"
                                MinHeight="210"
                                Margin="0,0,12,12"
                                Click="SupplementaryMonitor_Click">
                            <Border Background="{Binding SupplementaryMonitor.StatusColorHex}"
                                    CornerRadius="8"
                                    Padding="12"
                                    Width="300">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{Binding SupplementaryMonitor.MonitorName}"
                                               FontWeight="Bold"
                                               FontSize="18"/>

                                    <TextBlock Text="{Binding SupplementaryMonitor.StatusText, StringFormat='Status: {0}'}"/>
                                    <TextBlock Text="{Binding SupplementaryMonitor.StopTypeText, StringFormat='Stop: {0}'}"/>
                                    <TextBlock Text="{Binding SupplementaryMonitor.ReasonText, StringFormat='Reason: {0}'}"
                                               TextWrapping="Wrap"/>

                                    <TextBlock Text="{Binding SupplementaryMonitor.ReadyPowertrainCount, StringFormat='Ready Powertrains: {0}'}"/>
                                    <TextBlock Text="{Binding SupplementaryMonitor.ReadyPowertrainCapacity, StringFormat='Buffer Capacity: {0}'}"/>
                                    <TextBlock Text="{Binding SupplementaryMonitor.ReadyPowertrainUsagePercentage, StringFormat='Buffer Usage: {0:F1}%'}"/>

                                    <TextBlock Text="{Binding SupplementaryMonitor.NextReadyPowertrainVinText, StringFormat='Next Ready VIN: {0}'}"/>
                                    <TextBlock Text="{Binding SupplementaryMonitor.CurrentMarriageVinText, StringFormat='Marriage VIN: {0}'}"/>

                                    <TextBlock Text="{Binding SupplementaryMonitor.EngineDressingFaultedStations, StringFormat='ED Faulted: {0}'}"/>
                                    <TextBlock Text="{Binding SupplementaryMonitor.EngineDressingAverageWear, StringFormat='ED Avg Wear: {0:F1}%'}"/>
                                    <TextBlock Text="{Binding SupplementaryMonitor.EngineDressingMovementCountLastTakt, StringFormat='ED Moves Last Takt: {0}'}"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button Padding="0"
                                MinWidth="300"
                                MinHeight="210"
                                Margin="0,0,12,12"
                                Click="AsrsMonitor_Click">
                            <Border Background="{Binding AsrsMonitor.StatusColorHex}"
                                    CornerRadius="8"
                                    Padding="12"
                                    Width="300">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{Binding AsrsMonitor.MonitorName}"
                                               FontWeight="Bold"
                                               FontSize="18"/>

                                    <TextBlock Text="{Binding AsrsMonitor.StatusText, StringFormat='Status: {0}'}"/>
                                    <TextBlock Text="{Binding AsrsMonitor.StopTypeText, StringFormat='Stop: {0}'}"/>
                                    <TextBlock Text="{Binding AsrsMonitor.ReasonText, StringFormat='Reason: {0}'}"
                                               TextWrapping="Wrap"/>

                                    <TextBlock Text="{Binding AsrsMonitor.StoredVehicleCount, StringFormat='Stored Vehicles: {0}'}"/>
                                    <TextBlock Text="{Binding AsrsMonitor.Capacity, StringFormat='Capacity: {0}'}"/>
                                    <TextBlock Text="{Binding AsrsMonitor.UsagePercentage, StringFormat='Usage: {0:F1}%'}"/>

                                    <TextBlock Text="{Binding AsrsMonitor.NextRequiredVinText, StringFormat='Next Required VIN: {0}'}"/>
                                    <TextBlock Text="{Binding AsrsMonitor.IsNextRequiredVinPresent, StringFormat='Next VIN Present: {0}'}"/>
                                    <TextBlock Text="{Binding AsrsMonitor.IsReleaseReady, StringFormat='Release Ready: {0}'}"/>
                                </StackPanel>
                            </Border>
                        </Button>

                    </WrapPanel>

                </StackPanel>

            </Border>

        </ScrollViewer>

    </DockPanel>
</Window>